{
    "name": "promptjuggler/sdk",
    "description": "PHP SDK for the PromptJuggler API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "microsoft/kiota-bundle": "^2.0.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2.2",
        "phpunit/phpunit": "^11.5",
        "motley/ecs-config": "^3.0.2"
    },
    "autoload": {
        "psr-4": {
            "PromptJuggler\\Client\\": ["lib/", "src/"]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PromptJuggler\\Client\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    }
}
