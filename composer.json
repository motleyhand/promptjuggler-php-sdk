{
    "name": "promptjuggler/sdk",
    "description": "PHP SDK for the PromptJuggler API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "microsoft/kiota-bundle": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3",
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "PromptJuggler\\Client\\": ["lib/", "src/"]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PromptJuggler\\Client\\Tests\\": "tests/"
        }
    }
}
